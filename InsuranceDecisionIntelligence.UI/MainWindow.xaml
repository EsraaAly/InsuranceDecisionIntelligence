                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="250"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" x:Name="txtRowsCount" Text="Total Rows:" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="Import Date: " x:Name="txtImportedDate" FontWeight="SemiBold" Margin="0,0,0,8"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" x:Name="txtColumnsCount" Text="Total Columns:" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="Status: " x:Name="txtStatus" FontWeight="SemiBold"/>

                            </Grid>
                        </StackPanel>
                    </materialDesign:Card>

                    <!-- Data Preview Section -->
                    <materialDesign:Card Style="{StaticResource MaterialCard}" Margin="0,0,0,20">
                        <StackPanel>
                            <Grid Margin="0,0,0,15" >
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Orientation="Horizontal" Grid.ColumnSpan="2" Margin="0,0,154,0">
                                    <TextBlock Text="Data Preview" 
                                               FontSize="18" 
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"
                                               Margin="0,0,20,0"/>

                                 
                                        <TextBox  x:Name="txtPageNo" Text="1" Width="60" Height="30" Margin="0,0,10,0"
                                                  VerticalAlignment="Center"  FontSize="15" Padding="5"
                                                  PreviewTextInput="NumberValidationTextBox"
                                                  TextChanged="txtPageNo_TextChanged"/>
                                    <TextBlock Text="Page Number" VerticalAlignment="Center" Margin="0,0,20,0"/>


                                    <ComboBox x:Name="combPageSize" SelectedIndex="0" Width="80" Height="30" 
                                              Padding="5" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="15"
                                              SelectionChanged="combPageSize_SelectionChanged">
                                        <ComboBoxItem Content="100"/>
                                        <ComboBoxItem Content="200"/>
                                        <ComboBoxItem Content="500"/>
                                        <ComboBoxItem Content="1000"/>
                                    </ComboBox>
                                    <TextBlock Text="Page Size" VerticalAlignment="Center"/>


                                </StackPanel>

                                <!--<Button x:Name="btnRefrshData" Grid.Column="1"  Style="{StaticResource MaterialPrimaryButton}" 
                                        HorizontalAlignment="Right"
                                        Padding="10,8"
                                        Margin="60,0,20,0"
                                        Click="btnRefrshData_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Refresh" Margin="0,0,8,0"/>
                                        <TextBlock Text="Refresh"/>
                                    </StackPanel>
                                </Button>-->
                                <Button Grid.Column="2" 
                                        Style="{StaticResource MaterialOutlineButton}"
                                        Padding="15,5">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Download" Margin="0,0,5,0"/>
                                        <TextBlock Text="Export Current Page"/>
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <TextBlock x:Name="txtShowingRows" Text="" 
                                       FontSize="12" 
                                       Foreground="#666666"
                                       Margin="0,0,0,10"/>

                            <DataGrid x:Name="DG_FileData" Style="{StaticResource MaterialDataGrid}" Height="250"
                                      ItemsSource="{Binding}" AutoGenerateColumns="True" EnableRowVirtualization="True" IsReadOnly="True"/>

                            <!-- Pagination -->
                            <!--<StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">

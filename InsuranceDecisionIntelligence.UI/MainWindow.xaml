                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ProgressBar Value="{Binding Progress}" 
                                                         Maximum="100" 
                                                         Height="16" 
                                                         Margin="3"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Started At" Binding="{Binding StartedAt}" Width="80"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </materialDesign:Card>-->
                
                </StackPanel>
            </ScrollViewer>
            <!-- Right Panel -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">

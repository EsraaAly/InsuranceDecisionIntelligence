<Window x:Class="InsuranceDecisionIntelligence.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        Title="CSV Import Dashboard" 
        Height="900" 
        Width="1400"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#F5F5F5">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White" Padding="20,15" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Hamburger Menu -->
                <!--<Button Grid.Column="0" 
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Padding="8"
                        Margin="0,0,20,0">
                    <materialDesign:PackIcon Kind="Menu" Width="24" Height="24"/>
                </Button>-->

                <!-- Title -->
                <TextBlock Grid.Column="1" 
                           Text="CSV Import Dashboard" 
                           FontSize="24" 
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Foreground="#333333"/>

                <!-- Status Indicator -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8" Fill="#4CAF50" Margin="0,0,8,0"/>
                    <TextBlock Text="Background Import Service: Running" 
                               FontSize="14" 
                               Foreground="#666666"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content - Left and Right Panels -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="500"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="0,0,20,0">

                    <!-- Upload CSV File Section -->
                    <materialDesign:Card Style="{StaticResource MaterialCard}" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="Upload CSV File" 
                                   FontSize="18" 
                                   FontWeight="SemiBold" 
                                   Margin="0,0,0,20"/>

                            <!-- Drag and Drop Area -->
                            <Border Background="#F8F9FA" 
                                BorderBrush="#2196F3" 
                                BorderThickness="2" 
                                CornerRadius="8"
                                Padding="40,30"
                                Margin="0,0,0,20">
                                <StackPanel HorizontalAlignment="Center">
                                    <materialDesign:PackIcon Kind="CloudUpload" 
                                                         Width="48" 
                                                         Height="48" 
                                                         Foreground="#2196F3"
                                                         Margin="0,0,0,10"/>
                                    <TextBlock Text="Drag &amp; Drop CSV File Here" 
                                           FontSize="16" 
                                           Foreground="#666666"
                                           HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <!-- Browse File Button -->
                            <Button Style="{StaticResource MaterialPrimaryButton}" 
                                HorizontalAlignment="Stretch"
                                Padding="20,8"
                                Click="BrowseFile_Click">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="FolderOpen" Margin="0,0,8,0"/>
                                    <TextBlock Text="Browse File"/>
                                </StackPanel>
                            </Button>
                            <!--<Button Style="{StaticResource MaterialPrimaryButton}" 
                                    HorizontalAlignment="Stretch"
                                    Padding="20,8"
                                    Margin="0,10"
                                    Click="UploadFile_Click">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Upload" Margin="0,0,8,0"/>
                                <TextBlock Text="Upload File"/>
                            </StackPanel>
                        </Button>-->

                            <!-- File Info -->
                            <StackPanel Margin="0,15,0,0" Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="Allowed: .csv" FontSize="12" Foreground="#999999" Margin="0,0,15,0"/>
                                <TextBlock Text="Max Size: 200 MB" FontSize="12" Foreground="#999999"/>
                            </StackPanel>
                        </StackPanel>
                    </materialDesign:Card>

                    <!-- Uploaded Files Section -->
                    <materialDesign:Card Style="{StaticResource MaterialCard}" Padding="2">
                        <StackPanel>
                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" 
                                       Text="Uploaded Files" 
                                       FontSize="18" 
                                       Margin="5"
                                       FontWeight="SemiBold"/>

                                <Button 
                                    Style="{StaticResource MaterialDesignFlatButton}"
                                    Padding="5"
                                    Click="Refresh_Click" Margin="413,0,0,0">
                                    <materialDesign:PackIcon Kind="Refresh" Width="16" Height="16"/>
                                </Button>
                            </Grid>

                            <DataGrid x:Name="UploadedFileGrid" Style="{StaticResource MaterialDataGrid}" Height="200"
                                  ItemsSource="{Binding UploadedFiles}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="*" Visibility="Collapsed"/>
                                    <DataGridTextColumn Header="File Name" Binding="{Binding FileName}" Width="*"/>
                                    <DataGridTextColumn Header="Uploaded At" Binding="{Binding UploadedAt}" Width="120"/>
                                    <DataGridTemplateColumn Header="Preview" Width="80">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button x:Name="Preview" Style="{StaticResource MaterialPrimaryButton}" CommandParameter="{Binding}" Padding="0" Click="Preview_Click">
                                                    <materialDesign:PackIcon Kind="Show" Margin="0,0,8,0"/>
                                                </Button>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </materialDesign:Card>

                    <!-- Background Jobs Section -->
                    <materialDesign:Card Style="{StaticResource MaterialCard}">
                        <StackPanel>
                            <TextBlock Text="Background Jobs" 
                                   FontSize="18" 
                                   FontWeight="SemiBold" 
                                   Margin="0,0,0,15"/>

                            <DataGrid Style="{StaticResource MaterialDataGrid}" Height="150"
                                  ItemsSource="{Binding BackgroundJobs}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="File Name" Binding="{Binding FileName}" Width="*"/>
                                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="80"/>
                                    <DataGridTemplateColumn Header="Progress" Width="120">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ProgressBar Value="{Binding Progress}" 
                                                         Maximum="100" 
                                                         Height="16" 
                                                         Margin="3"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Started At" Binding="{Binding StartedAt}" Width="80"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </materialDesign:Card>
                </StackPanel>
            </ScrollViewer>
            <!-- Right Panel -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <!-- File Details Section -->
                    <materialDesign:Card Style="{StaticResource MaterialCard}" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock x:Name="txtFileName" Text="File Details" 
                                       FontSize="18" 
                                       FontWeight="SemiBold" 
                                       Margin="0,0,0,20"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Total Rows:" Foreground="#666666" Margin="0,0,0,8"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="" x:Name="txtRowsCount" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="Import Date: " x:Name="txtImportedDate" FontWeight="SemiBold" Margin="0,0,0,8"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Total Columns:" Foreground="#666666" Margin="0,0,0,8"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="" x:Name="txtColumnsCount" FontWeight="SemiBold" Margin="0,0,0,8"/>

                                <TextBlock Grid.Row="1" Grid.Column="2" Text="Status: " x:Name="txtStatus" FontWeight="SemiBold"/>

                            </Grid>
                        </StackPanel>
                    </materialDesign:Card>

                    <!-- Data Preview Section -->
                    <materialDesign:Card Style="{StaticResource MaterialCard}" Margin="0,0,0,20">
                        <StackPanel>
                            <Grid Margin="0,0,0,15" >
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Orientation="Horizontal" Grid.ColumnSpan="2" Margin="0,0,154,0">
                                    <TextBlock Text="Data Preview" 
                                               FontSize="18" 
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"
                                               Margin="0,0,20,0"/>

                                    <Border BorderBrush="Black" BorderThickness="1" Margin="0,0,10,0">
                                        <TextBox  x:Name="txtPageNo" Text="1" Width="60" Height="30" 
                                                  VerticalAlignment="Center"  FontSize="15" Padding="5"
                                                  PreviewTextInput="NumberValidationTextBox"
                                                  TextChanged="txtPageNo_TextChanged"/>
                                    </Border>
                                    <TextBlock Text="Page Number" VerticalAlignment="Center" Margin="0,0,20,0"/>


                                    <ComboBox x:Name="combPageSize" SelectedIndex="0" Width="80" Height="30" 
                                              Padding="5" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="15"
                                              SelectionChanged="combPageSize_SelectionChanged">
                                        <ComboBoxItem Content="100"/>
                                        <ComboBoxItem Content="200"/>
                                        <ComboBoxItem Content="500"/>
                                        <ComboBoxItem Content="1000"/>
                                    </ComboBox>
                                    <TextBlock Text="Page Size" VerticalAlignment="Center"/>


                                </StackPanel>

                                <!--<Button x:Name="btnRefrshData" Grid.Column="1"  Style="{StaticResource MaterialPrimaryButton}" 
                                        HorizontalAlignment="Right"
                                        Padding="10,8"
                                        Margin="60,0,20,0"
                                        Click="btnRefrshData_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Refresh" Margin="0,0,8,0"/>
                                        <TextBlock Text="Refresh"/>
                                    </StackPanel>
                                </Button>-->
                                <Button Grid.Column="2" 
                                        Style="{StaticResource MaterialOutlineButton}"
                                        Padding="15,5">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Download" Margin="0,0,5,0"/>
                                        <TextBlock Text="Export Current Page"/>
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <TextBlock x:Name="txtShowingRows" Text="" 
                                       FontSize="12" 
                                       Foreground="#666666"
                                       Margin="0,0,0,10"/>

                            <DataGrid x:Name="DG_FileData" Style="{StaticResource MaterialDataGrid}" Height="250"
                                      ItemsSource="{Binding}" AutoGenerateColumns="True" EnableRowVirtualization="True" IsReadOnly="True"/>

                            <!-- Pagination -->
                            <!--<StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
                                <Button x:Name="btnFirstPage" Style="{StaticResource MaterialDesignFlatButton}" Padding="8,4" Margin="2">First</Button>
                                <Button x:Name="btnPreviousPage" Style="{StaticResource MaterialDesignFlatButton}" Padding="8,4" Margin="2">Previous</Button>
                                <Button x:Name="btnPreviousButtons" Style="{StaticResource MaterialDesignFlatButton}" Click="btnPreviousButtons_Click" Padding="8,4" Margin="2" Content="..."></Button>
                                <Button x:Name="btnNum1" Style="{StaticResource MaterialDesignFlatButton}" Padding="8,4" Margin="2" Content="1"></Button>
                                <Button x:Name="btnNum2" Style="{StaticResource MaterialDesignFlatButton}" Padding="8,4" Margin="2" Content="2"></Button>
                                <Button x:Name="btnNum3" Style="{StaticResource MaterialDesignFlatButton}" Padding="8,4" Margin="2" Content="3"></Button>
                                <Button x:Name="btnNum4" Style="{StaticResource MaterialDesignFlatButton}" Padding="8,4" Margin="2" Content="4"></Button>
                                <Button x:Name="btnNextButtons" Style="{StaticResource MaterialDesignFlatButton}" Click="btnNextButtons_Click" Padding="8,4" Margin="2" Content="..."></Button>
                                <Button x:Name="btnNextPage" Style="{StaticResource MaterialDesignFlatButton}" Padding="8,4" Margin="2">Next</Button>
                                <Button x:Name="btnLastPage" Style="{StaticResource MaterialDesignFlatButton}" Padding="8,4" Margin="2">Last</Button>
                            </StackPanel>-->

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="10">
                                <Button x:Name="btnFirst" Content="&lt;&lt;" Click="First_Click" Width="35" Margin="2" Padding="0"/>
                                <Button x:Name="btnPrev" Content="&lt;" Click="Prev_Click" Width="35" Margin="2" Padding="0"/>

                                <ItemsControl x:Name="pagesControl">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Content="{Binding}" Click="PageNumber_Click" Width="40" Margin="2" Padding="5"
                                                    Style="{StaticResource PaginationButtons}" Loaded="Button_Loaded"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <Button x:Name="btnNext" Content="&gt;" Click="Next_Click" Width="35" Margin="2" Padding="0"/>
                                <Button x:Name="btnLast" Content="&gt;&gt;" Click="Last_Click" Width="35" Margin="2" Padding="0"/>
                            </StackPanel>
                        </StackPanel>
                    </materialDesign:Card>

                    <!-- Dashboard (Based on File Data) Section -->
                    <materialDesign:Card Style="{StaticResource MaterialCard}" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="Dashboard (Based on File Data)" 
                                       FontSize="18" 
                                       FontWeight="SemiBold" 
                                       Margin="0,0,0,20"/>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Top Row: Line Chart and Bar Chart -->
                                <Grid Grid.Row="0" Margin="0,0,0,20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Rows Over Time Line Chart -->
                                    <StackPanel Grid.Column="0" Margin="0,0,15,0">
                                        <TextBlock Text="Rows Over Time" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                        <lvc:CartesianChart Height="250"
                                                            Series="{Binding LineChartData}"
                                                            XAxes="{Binding LineChartXAxes}"
                                                            YAxes="{Binding LineChartYAxes}">
                                        </lvc:CartesianChart>
                                    </StackPanel>

                                    <!-- Top 10 Values Bar Chart -->
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Top 10 Values (Column 4)" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                        <lvc:CartesianChart Height="250"
                                                            Series="{Binding BarChartData}"
                                                            XAxes="{Binding BarChartXAxes}"
                                                            YAxes="{Binding BarChartYAxes}">
                                        </lvc:CartesianChart>
                                    </StackPanel>
                                </Grid>

                                <!-- Bottom Row: Pie Chart and Summary Statistics -->
                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Distribution Pie Chart -->
                                    <StackPanel Grid.Column="0" Margin="0,0,15,0">
                                        <TextBlock Text="Distribution (Column 5)" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                        <lvc:PieChart Height="200"
                                                      Series="{Binding PieChartData}">
                                        </lvc:PieChart>
                                    </StackPanel>

                                    <!-- Summary Statistics -->
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Summary Statistics" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Total Rows:" Foreground="#666666" Margin="0,0,0,5"/>
                                            <TextBlock Grid.Row="0" Grid.Column="1" Text="105,555" FontWeight="SemiBold" Margin="0,0,0,5"/>

                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Total Columns:" Foreground="#666666" Margin="0,0,0,5"/>
                                            <TextBlock Grid.Row="1" Grid.Column="1" Text="30" FontWeight="SemiBold" Margin="0,0,0,5"/>

                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Numeric Columns:" Foreground="#666666" Margin="0,0,0,5"/>
                                            <TextBlock Grid.Row="2" Grid.Column="1" Text="12" FontWeight="SemiBold" Margin="0,0,0,5"/>

                                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Date Columns:" Foreground="#666666" Margin="0,0,0,5"/>
                                            <TextBlock Grid.Row="3" Grid.Column="1" Text="4" FontWeight="SemiBold" Margin="0,0,0,5"/>

                                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Text Columns:" Foreground="#666666" Margin="0,0,0,5"/>
                                            <TextBlock Grid.Row="4" Grid.Column="1" Text="14" FontWeight="SemiBold" Margin="0,0,0,5"/>

                                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Null Values:" Foreground="#666666"/>
                                            <TextBlock Grid.Row="5" Grid.Column="1" Text="2.35%" FontWeight="SemiBold"/>
                                        </Grid>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </StackPanel>
                    </materialDesign:Card>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Footer -->
        <Border Grid.Row="2" Background="White" Padding="20,15" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Last Refresh -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Last Refresh: 5/18/2024 10:20:30 AM" Foreground="#666666"/>
                    <Button Style="{StaticResource MaterialDesignFlatButton}" 
                            Padding="5" 
                            Margin="10,0,0,0"
                            Click="Refresh_Click">
                        <materialDesign:PackIcon Kind="Refresh" Width="16" Height="16"/>
                    </Button>
                </StackPanel>

                <!-- Status Message -->
                <TextBlock Grid.Column="1" 
                           Text="Bulk INSERT is running in background." 
                           Foreground="#FF9800"
                           VerticalAlignment="Center"
                           Margin="0,0,20,0"/>

                <!-- View Logs Button -->
                <Button Grid.Column="2" 
                        Style="{StaticResource MaterialOutlineButton}"
                        Padding="15,5">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="FileDocument" Margin="0,0,5,0"/>
                        <TextBlock Text="View Logs"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>

                                <Button x:Name="btnNum2" Style="{StaticResource MaterialDesignFlatButton}" Padding="8,4" Margin="2" Content="2"></Button>
                                <Button x:Name="btnNum3" Style="{StaticResource MaterialDesignFlatButton}" Padding="8,4" Margin="2" Content="3"></Button>
                                <Button x:Name="btnNum4" Style="{StaticResource MaterialDesignFlatButton}" Padding="8,4" Margin="2" Content="4"></Button>

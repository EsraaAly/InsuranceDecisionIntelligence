<Window x:Class="InsuranceDecisionIntelligence.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        Title="CSV Import Dashboard" 
        Height="790" 
        Width="1400"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#F5F5F5">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White" Padding="20,15" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Hamburger Menu -->
                <!--<Button Grid.Column="0" 
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Padding="8"
                        Margin="0,0,20,0">
                    <materialDesign:PackIcon Kind="Menu" Width="24" Height="24"/>
                </Button>-->

                <!-- Title -->
                <TextBlock Grid.Column="1" 
                           Text="CSV Import Dashboard" 
                           FontSize="24" 
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Foreground="#333333"/>

                <!-- Status Indicator -->
                <!--<StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8" Fill="#4CAF50" Margin="0,0,8,0"/>
                    <TextBlock Text="Background Import Service: Running" 
                               FontSize="14" 
                               Foreground="#666666"/>
                </StackPanel>-->
            </Grid>
        </Border>

        <!-- Main Content - Left and Right Panels -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="400"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="0,0,20,0">

                    <!-- Upload CSV File Section -->
                    <materialDesign:Card Style="{StaticResource MaterialCard}" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="Upload CSV File" 
                                   FontSize="18" 
                                   FontWeight="SemiBold" 
                                   Margin="0,0,0,20"/>

                            <!-- Drag and Drop Area -->
                            <Border Background="#F8F9FA" 
                                BorderBrush="#2196F3" 
                                BorderThickness="2" 
                                CornerRadius="8"
                                Padding="40,30"
                                Margin="0,0,0,20">
                                <StackPanel HorizontalAlignment="Center">
                                    <materialDesign:PackIcon Kind="CloudUpload" 
                                                         Width="48" 
                                                         Height="48" 
                                                         Foreground="#2196F3"
                                                         Margin="0,0,0,10"/>
                                    <TextBlock Text="Drag &amp; Drop CSV File Here" 
                                           FontSize="16" 
                                           Foreground="#666666"
                                           HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <!-- Browse File Button -->
                            <Button Style="{StaticResource MaterialPrimaryButton}" 
                                HorizontalAlignment="Stretch"
                                Padding="20,8"
                                Click="BrowseFile_Click">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="FolderOpen" Margin="0,0,8,0"/>
                                    <TextBlock Text="Browse File"/>
                                </StackPanel>
                            </Button>
                            <!--<Button Style="{StaticResource MaterialPrimaryButton}" 
                                    HorizontalAlignment="Stretch"
                                    Padding="20,8"
                                    Margin="0,10"
                                    Click="UploadFile_Click">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Upload" Margin="0,0,8,0"/>
                                <TextBlock Text="Upload File"/>
                            </StackPanel>
                        </Button>-->

                            <!-- File Info -->
                            <StackPanel Margin="0,15,0,0" Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="Allowed: .csv" FontSize="12" Foreground="#999999" Margin="0,0,15,0"/>
                                <TextBlock Text="Max Size: 200 MB" FontSize="12" Foreground="#999999"/>
                            </StackPanel>
                        </StackPanel>
                    </materialDesign:Card>

                    <!-- Uploaded Files Section -->
                    <materialDesign:Card Style="{StaticResource MaterialCard}" Padding="2">
                        <StackPanel>
                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" 
                                       Text="Uploaded Files" 
                                       FontSize="18" 
                                       Margin="5"
                                       FontWeight="SemiBold"/>

                                <Button 
                                    Style="{StaticResource MaterialDesignFlatButton}"
                                    Padding="5"
                                    Click="Refresh_Click" Margin="310,0,0,0">
                                    <materialDesign:PackIcon Kind="Refresh" Width="16" Height="16"/>
                                </Button>
                            </Grid>

                            <DataGrid x:Name="UploadedFileGrid" Style="{StaticResource MaterialDataGrid}" Height="200"
                                  ItemsSource="{Binding UploadedFiles}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="*" Visibility="Collapsed"/>
                                    <DataGridTextColumn Header="File Name" Binding="{Binding FileName}" Width="*"/>
                                    <DataGridTextColumn Header="Uploaded At" Binding="{Binding UploadedAt}" Width="120"/>
                                    <DataGridTemplateColumn Header="Preview" Width="80">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button x:Name="Preview" Style="{StaticResource MaterialPrimaryButton}" CommandParameter="{Binding}" Padding="0" Click="Preview_Click">
                                                    <materialDesign:PackIcon Kind="Show" Margin="0,0,8,0"/>
                                                </Button>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </materialDesign:Card>

                    <!-- Background Jobs Section -->
                    <!--<materialDesign:Card Style="{StaticResource MaterialCard}">
                        <StackPanel>
                            <TextBlock Text="Background Jobs" 
                                   FontSize="18" 
                                   FontWeight="SemiBold" 
                                   Margin="0,0,0,15"/>

                            <DataGrid Style="{StaticResource MaterialDataGrid}" Height="150"
                                  ItemsSource="{Binding BackgroundJobs}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="File Name" Binding="{Binding FileName}" Width="*"/>
                                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="80"/>

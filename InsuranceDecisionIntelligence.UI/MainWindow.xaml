                            </StackPanel>-->

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="10">
                                <Button x:Name="btnFirst" Content="&lt;&lt;" Click="First_Click" Width="35" Margin="2" Padding="0"/>
                                <Button x:Name="btnPrev" Content="&lt;" Click="Prev_Click" Width="35" Margin="2" Padding="0"/>

                                <ItemsControl x:Name="pagesControl">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Content="{Binding}" Click="PageNumber_Click" Width="40" Margin="2" Padding="5"
                                                    Style="{StaticResource PaginationButtons}"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <Button x:Name="btnNext" Content="&gt;" Click="Next_Click" Width="35" Margin="2" Padding="0"/>
                                <Button x:Name="btnLast" Content="&gt;&gt;" Click="Last_Click" Width="35" Margin="2" Padding="0"/>
                            </StackPanel>
                        </StackPanel>
                    </materialDesign:Card>

                    <!-- Dynamic Dashboard Section -->
